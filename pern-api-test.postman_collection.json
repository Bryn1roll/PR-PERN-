      "key": "serviceA_base",
      "value": "http://localhost:3000"
    },
    {
      "key": "serviceB_base",
      "value": "http://localhost:4000"
    },
    {
      "key": "task_id",
      "value": "1"
    },
    {
      "key": "note_id",
      "value": "1"
    }
