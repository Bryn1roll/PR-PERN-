            "method": "POST",
            "header": [{ "key": "Content-Type", "value": "application/json" }],
            "body": { "mode": "raw", "raw": "{\n  \"taskId\": \"{{task_id}}\",\n  \"to\": \"to@localhost\"\n}" },
            "url": { "raw": "{{serviceB_base}}/email/send", "host": ["{{serviceB_base}}"], "path": ["email", "send"] }
