{
  "info": {
    "name": "PR-PERN Docker Services API Test",
    "description": "Коллекция для тестирования сервисов A (:3000) и B (:4000) с проксированием. Базовые проверки + CRUD + сценарии взаимодействия.",
    "schema": "https://schema.getpostman.com/json/collection/v2.1.0/collection.json"
  },
  "variable": [
