{
  "info": {
    "name": "PERN-labs API",
    "description": "Минимальный набор запросов для проверки ЛР1–ЛР4: CRUD задач (сервис A), CRUD заметок (сервис B), межсервисное взаимодействие B→A, почта SMTP/IMAP/POP3.",
    "schema": "https://schema.getpostman.com/json/collection/v2.1.0/collection.json"
  },
  "variable": [
    { "key": "serviceA_base", "value": "http://localhost:3000" },
    { "key": "serviceB_base", "value": "http://localhost:4000" },
    { "key": "task_id",       "value": "1" },
    { "key": "note_id",       "value": "1" }
  ],
  "item": [
    {
      "name": "ЛР3 — CRUD Tasks (сервис A)",
      "item": [
        {
          "name": "GET /tasks",
          "request": {
            "method": "GET", "header": [],
            "url": { "raw": "{{serviceA_base}}/tasks", "host": ["{{serviceA_base}}"], "path": ["tasks"] }
          }
        },
        {
          "name": "POST /tasks",
          "request": {
            "method": "POST",
            "header": [{ "key": "Content-Type", "value": "application/json" }],
            "body": { "mode": "raw", "raw": "{\n  \"title\": \"Новая задача\",\n  \"completed\": false\n}" },
            "url": { "raw": "{{serviceA_base}}/tasks", "host": ["{{serviceA_base}}"], "path": ["tasks"] }
          }
        },
        {
          "name": "GET /tasks/:id",
          "request": {
            "method": "GET", "header": [],
            "url": { "raw": "{{serviceA_base}}/tasks/{{task_id}}", "host": ["{{serviceA_base}}"], "path": ["tasks", "{{task_id}}"] }
          }
        },
        {
          "name": "PUT /tasks/:id",
          "request": {
            "method": "PUT",
            "header": [{ "key": "Content-Type", "value": "application/json" }],
            "body": { "mode": "raw", "raw": "{\n  \"title\": \"Обновлённая задача\",\n  \"completed\": true\n}" },
            "url": { "raw": "{{serviceA_base}}/tasks/{{task_id}}", "host": ["{{serviceA_base}}"], "path": ["tasks", "{{task_id}}"] }
          }
        },
        {
          "name": "DELETE /tasks/:id",
          "request": {
            "method": "DELETE", "header": [],
